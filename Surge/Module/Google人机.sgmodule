#!name=Google人机
#!desc=GoogleCAPTCHA

[Script]
# 片段：https://raw.githubusercontent.com/NobyDa/Script/master/QuantumultX/Snippet/GoogleCAPTCHA.snippet
Google_CAPTCHA = type=http-response, pattern=^https:\/\/www\.google\.com(?:\.[a-z]+|)\/(?:search\?(?:|.+?&)q=|$), script-path=https://github.com/toechon/gong/raw/master/Surge/Scripts/Google_CAPTCHA.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% www.google.com*
